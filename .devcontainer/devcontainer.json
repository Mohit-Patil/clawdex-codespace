{
  "name": "Clawdex Codespace",
  "forwardPorts": [8787, 8788],
  "portsAttributes": {
    "8787": {
      "label": "Clawdex Bridge",
      "onAutoForward": "silent"
    },
    "8788": {
      "label": "Clawdex Browser Preview",
      "onAutoForward": "silent"
    }
  },
  "updateContentCommand": "bash -lc 'npm install -g --no-fund --no-audit clawdex-mobile@internal @openai/codex'",
  "postStartCommand": "bash -lc 'nohup env CLAWDEX_WORKSPACE_ROOT=\"$PWD\" node \"$(npm root -g)/clawdex-mobile/scripts/codespaces-bootstrap.js\" > .bridge-bootstrap.log 2>&1 < /dev/null &'",
  "waitFor": "updateContentCommand"
}

{
  "name": "Clawdex Codespace",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8787, 8788],
  "portsAttributes": {
    "8787": {
      "label": "Clawdex Bridge",
      "onAutoForward": "silent"
    },
    "8788": {
      "label": "Clawdex Browser Preview",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "bash -lc 'npm install -g clawdex-mobile@internal @openai/codex && CLAWDEX_WORKSPACE_ROOT=\"$PWD\" node \"$(npm root -g)/clawdex-mobile/scripts/codespaces-bootstrap.js\" --prepare-only'",
  "postStartCommand": "bash -lc 'CLAWDEX_WORKSPACE_ROOT=\"$PWD\" node \"$(npm root -g)/clawdex-mobile/scripts/codespaces-bootstrap.js\"'"
}

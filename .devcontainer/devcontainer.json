{
  "name": "Clawdex Codespace",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8787, 8788],
  "portsAttributes": {
    "8787": {
      "label": "Clawdex Bridge",
      "onAutoForward": "silent"
    },
    "8788": {
      "label": "Clawdex Browser Preview",
      "onAutoForward": "silent"
    }
  },
  "updateContentCommand": "bash -lc 'npm install -g --no-fund --no-audit clawdex-mobile@internal @openai/codex'",
  "postCreateCommand": "bash -lc 'env CLAWDEX_WORKSPACE_ROOT=\"$PWD\" node \"$(npm root -g)/clawdex-mobile/scripts/codespaces-bootstrap.js\" > .bridge-bootstrap.log 2>&1'",
  "postStartCommand": "bash -lc 'env CLAWDEX_WORKSPACE_ROOT=\"$PWD\" node \"$(npm root -g)/clawdex-mobile/scripts/codespaces-bootstrap.js\" > .bridge-bootstrap.log 2>&1'",
  "waitFor": "postCreateCommand"
}
